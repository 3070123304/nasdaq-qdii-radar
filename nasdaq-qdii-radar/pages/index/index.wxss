/* 首页 · 简洁仪表盘风格（对齐设计稿） */
.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f0f2f5;
}

/* —— 顶部 —— */
.hero {
  flex-shrink: 0;
  position: relative;
  z-index: 1;
  padding-bottom: 56px;
  color: #fff;
  overflow: hidden;
}

/* 本地图不可用 WXSS background-image，必须用 <image> */
.hero-bg-img {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  display: block;
  background-color: #020617;
}

.hero-bg-mask {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  background: linear-gradient(
      105deg,
      rgba(2, 6, 23, 0.82) 0%,
      rgba(2, 6, 23, 0.35) 42%,
      transparent 72%
    ),
    linear-gradient(180deg, transparent 52%, rgba(15, 23, 42, 0.28) 100%);
}

.hero-inner {
  position: relative;
  z-index: 2;
  padding: 0 16px;
}

.hero-top {
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

.hero-text {
  flex: 1;
  min-width: 0;
}

.hero-title-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 0 6px;
}

.hero-title-main {
  font-size: 30px;
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: 0.02em;
  color: #ffffff;
}

.hero-title-accent {
  font-size: 30px;
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: 0.02em;
  color: #1890ff;
}

.hero-sub {
  display: block;
  margin-top: 8px;
  font-size: 16px;
  color: rgba(250, 248, 248, 0.952);
  line-height: 1.4;
}

.hero-meta {
  margin-top: 16px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6px;
}

.update-area {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.risk-tip {
  width: 100%;
  font-size: 11px;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.72);
}

.update-pill {
  flex-shrink: 0;
  display: inline-flex;
  flex-wrap: nowrap;
  align-items: center;
  gap: 6px;
  min-width: 0;
}

.update-clock {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: #2f80ff;
  position: relative;
  flex-shrink: 0;
  box-shadow: 0 2px 8px rgba(47, 128, 255, 0.35);
}

.update-clock::before {
  content: '';
  position: absolute;
  left: 6px;
  top: 3px;
  width: 1.5px;
  height: 4px;
  border-radius: 2px;
  background: #fff;
}

.update-clock::after {
  content: '';
  position: absolute;
  left: 6px;
  top: 6px;
  width: 4px;
  height: 1.5px;
  border-radius: 2px;
  background: #fff;
  transform-origin: 1px center;
  transform: rotate(35deg);
}

.pill-label {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.96);
  line-height: 18px;
  white-space: nowrap;
  margin-right: -6px;
}

.pill-time {
  font-size: 14px;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.96);
  line-height: 18px;
  white-space: nowrap;
}

.meta-hint {
  flex: 1;
  font-size: 11px;
  color: rgba(255, 255, 255, 0.78);
  text-align: right;
  line-height: 18px;
  max-width: 52%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: clip;
}

/* —— 滚动区：scroll-y 必须有明确高度，否则中间区域可能高度为 0 —— */
.main-scroll {
  width: 100%;
  box-sizing: border-box;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
  margin-top: -40px;
}

.sheet {
  padding: 0 12px;
  margin-top: 0;
  position: relative;
  z-index: 3;
}

/* —— 汇总卡：横向扁长方形 + 文案单行 —— */
.summary-row {
  display: flex;
  gap: 10px;
  align-items: stretch;
}

.sum-card {
  flex: 1;
  background: #fff;
  border-radius: 16px;
  padding: 14px 12px;
  box-shadow: 0 6px 18px rgba(0, 21, 41, 0.1);
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10px;
  min-width: 0;
  box-sizing: border-box;
}

.sum-icon-circle {
  width: 46px;
  height: 46px;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sum-icon-circle--blue {
  background: rgba(24, 144, 255, 0.15);
}

.sum-icon-circle--green {
  background: rgba(82, 196, 26, 0.16);
}

.sum-icon-circle--orange {
  background: rgba(250, 140, 22, 0.16);
}

.ico-bag-wrap {
  position: relative;
  width: 18px;
  height: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 购物袋 + 角标勾 */
.ico-bag {
  width: 12px;
  height: 9px;
  border: 1.5px solid #1890ff;
  border-radius: 2px 2px 3px 3px;
  position: relative;
  margin-top: 3px;
  box-sizing: border-box;
}

.ico-bag::before {
  content: '';
  position: absolute;
  left: 50%;
  top: -4px;
  transform: translateX(-50%);
  width: 7px;
  height: 3px;
  border: 1.5px solid #1890ff;
  border-bottom: none;
  border-radius: 5px 5px 0 0;
  box-sizing: border-box;
}

.ico-bag-check {
  position: absolute;
  right: -2px;
  bottom: -2px;
  font-size: 8px;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #1890ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ico-bell-ring {
  width: 12px;
  height: 9px;
  border: 1.5px solid #52c41a;
  border-radius: 8px 8px 3px 3px;
  position: relative;
  margin-top: 1px;
  box-sizing: border-box;
}

.ico-bell-ring::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -3px;
  transform: translateX(-50%);
  width: 5px;
  height: 2px;
  background: #52c41a;
  border-radius: 2px;
}

.ico-money {
  width: 22px;
  height: 22px;
  border: 2px solid #fa8c16;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  position: relative;
}

.ico-money::after {
  content: '';
  position: absolute;
  left: 4px;
  right: 4px;
  bottom: -5px;
  height: 4px;
  border-radius: 999px;
  background: rgba(250, 140, 22, 0.35);
}

.ico-money-symbol {
  font-size: 14px;
  font-weight: 700;
  color: #fa8c16;
  line-height: 1;
}

.sum-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
  justify-content: center;
}

.sum-label {
  font-size: 15px;
  font-weight: 600;
  color: #262626;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 2px;
}

.sum-value-row {
  margin-top: 1px;
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: baseline;
  gap: 2px;
  min-width: 0;
  max-width: 100%;
}

.sum-num {
  font-size: 20px;
  font-weight: 700;
  color: #262626;
  font-variant-numeric: tabular-nums;
  line-height: 1.12;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sum-unit {
  font-size: 15px;
  font-weight: 600;
  color: #595959;
  flex-shrink: 0;
}

.sum-diff-row {
  margin-top: 4px;
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: baseline;
  font-size: 14px;
  line-height: 1.2;
  white-space: nowrap;
}

.sum-diff-prefix {
  color: #8c8c8c;
  flex-shrink: 0;
  white-space: nowrap;
}

.sum-diff-num {
  font-weight: 600;
  font-variant-numeric: tabular-nums;
  flex-shrink: 0;
  white-space: nowrap;
}

.sum-diff-num--up {
  color: #f5222d;
}

.sum-diff-num--down {
  color: #52c41a;
}

/* —— 今日速览 —— */
.glance {
  margin-top: 12px;
  padding: 12px 14px;
  border-radius: 10px;
  background: linear-gradient(90deg, #e6f7ff 0%, #f0f9ff 100%);
  border: 1px solid rgba(24, 144, 255, 0.12);
  display: flex;
  align-items: center;
  gap: 8px;
}

.glance:active {
  opacity: 0.92;
}

.glance-tag {
  flex-shrink: 0;
  font-size: 13px;
  font-weight: 600;
  color: #166ec0;
}

.glance-msg {
  flex: 1;
  font-size: 12px;
  color: #595959;
  line-height: 1.45;
}

.glance-chev {
  flex-shrink: 0;
  font-size: 18px;
  color: #bfbfbf;
}

/* —— 列表标题 —— */
.block-head {
  margin-top: 20px;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.block-title {
  font-size: 16px;
  font-weight: 700;
  color: #262626;
}

.block-filters {
  display: flex;
  gap: 6px;
}

.filter-chip {
  font-size: 11px;
  color: #595959;
  padding: 5px 10px;
  border-radius: 999px;
  background: #fff;
  border: 1px solid #e8e8e8;
}

/* —— 基金表 —— */
.fund-panel {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 10px rgba(0, 21, 41, 0.06);
}

.fund-thead {
  display: flex;
  align-items: center;
  padding: 10px 12px;
  background: #fafafa;
}

.th {
  font-size: 11px;
  color: #8c8c8c;
}

.th-name {
  flex: 1;
  min-width: 0;
}

.th-limit {
  width: 86px;
  text-align: right;
}

.th-status {
  width: 58px;
  text-align: center;
}

.fund-row {
  display: flex;
  align-items: center;
  padding: 14px 12px;
  border-top: 1px solid #f0f0f0;
}

.fund-row:active {
  background: #fafafa;
}

.td-name {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10px;
}

.logo {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  color: #fff;
  font-size: 14px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.name-wrap {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.fund-name {
  font-size: 13px;
  font-weight: 600;
  color: #262626;
  line-height: 1.35;
  white-space: normal;
  word-break: break-all;

  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.fund-code {
  font-size: 12px;
  font-weight: 500;
  color: #9ca3af;
  font-variant-numeric: tabular-nums;
}

.td-limit {
  width: 86px;
  text-align: right;
  font-size: 14px;
  font-weight: 700;
  color: #262626;
  font-variant-numeric: tabular-nums;
}

.td-limit--muted {
  font-size: 12px;
  font-weight: 600;
  color: #8c8c8c;
}

.td-status {
  width: 58px;
  display: flex;
  justify-content: center;
}

.status-tag {
  padding: 3px 8px;
  border-radius: 6px;
  font-size: 11px;
  font-weight: 500;
}

.status-ok {
  color: #389e0d;
  background: #f6ffed;
}

.status-warn {
  color: #d46b08;
  background: #fff7e6;
}

.status-off {
  color: #8c8c8c;
  background: #f5f5f5;
}

.scroll-bottom-space {
  height: 20px;
}

.sum-icon-box {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sum-icon-box--blue {
  background: rgba(24, 144, 255, 0.13);
}

.sum-icon-box--orange {
  background: rgba(250, 140, 22, 0.14);
}

.sum-icon-symbol {
  font-size: 22px;
  font-weight: 800;
  line-height: 1;
}

.sum-icon-box--blue .sum-icon-symbol {
  color: #1890ff;
}

.sum-icon-box--orange .sum-icon-symbol {
  color: #fa8c16;
}
