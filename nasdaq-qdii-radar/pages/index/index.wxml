<view class="page">
  <view class="hero" style="padding-top: {{statusBarHeight + 10}}px;">
    <image class="hero-bg-img" src="/images/header-bg.png" mode="aspectFill" />
    <view class="hero-bg-mask"></view>

    <view class="hero-inner">
      <view class="hero-top">
        <view class="hero-text">
          <view class="hero-title-row">
            <text class="hero-title-main">纳指QDII</text>
            <text class="hero-title-accent">限额雷达</text>
          </view>
          <text class="hero-sub">一眼看全市场纳斯达克QDII基金限额</text>
        </view>
      </view>

      <view class="hero-meta">
        <view class="update-pill">
          <text class="pill-label">数据更新时间：</text>
          <text class="pill-time">{{updateDateLabel}}</text>
        </view>
        <text class="meta-hint">数据每日更新，部分基金实时变化</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="main-scroll" style="height: {{scrollHeight}}px" show-scrollbar="{{false}}">
    <view class="sheet">
      <view class="summary-row">
        <view class="sum-card">
          <view class="sum-icon-circle sum-icon-circle--blue">
            <view class="ico-bag-wrap">
              <view class="ico-bag"></view>
              <text class="ico-bag-check">✓</text>
            </view>
          </view>
          <view class="sum-body">
            <text class="sum-label">今日可买基金</text>
            <view class="sum-value-row">
              <text class="sum-num">{{summary.buyable.value}}</text>
              <text class="sum-unit">只</text>
            </view>
            <view class="sum-diff-row">
              <text class="sum-diff-prefix">较昨日 </text>
              <text class="sum-diff-num {{summary.buyable.trend === 'down' ? 'sum-diff-num--down' : 'sum-diff-num--up'}}">{{summary.buyable.deltaText}}</text>
            </view>
          </view>
        </view>
        <view class="sum-card">
          <view class="sum-icon-circle sum-icon-circle--green">
            <view class="ico-bell-ring"></view>
          </view>
          <view class="sum-body">
            <text class="sum-label">恢复申购</text>
            <view class="sum-value-row">
              <text class="sum-num">{{summary.resumed.value}}</text>
              <text class="sum-unit">只</text>
            </view>
            <view class="sum-diff-row">
              <text class="sum-diff-prefix">较昨日 </text>
              <text class="sum-diff-num {{summary.resumed.trend === 'down' ? 'sum-diff-num--down' : 'sum-diff-num--up'}}">{{summary.resumed.deltaText}}</text>
            </view>
          </view>
        </view>
        <view class="sum-card">
          <view class="sum-icon-circle sum-icon-circle--orange">
            <view class="ico-pie"></view>
          </view>
          <view class="sum-body">
            <text class="sum-label">累计可购额度</text>
            <view class="sum-value-row">
              <text class="sum-num">{{summary.totalLimit.value}}</text>
              <text class="sum-unit">{{summary.totalLimit.unit}}</text>
            </view>
            <view class="sum-diff-row">
              <text class="sum-diff-prefix">较昨日 </text>
              <text class="sum-diff-num {{summary.totalLimit.trend === 'down' ? 'sum-diff-num--down' : 'sum-diff-num--up'}}">{{summary.totalLimit.deltaText}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="glance" bindtap="onGlanceTap">
        <text class="glance-tag">今日速览</text>
        <text class="glance-msg">{{glance}}</text>
        <text class="glance-chev">›</text>
      </view>

      <view class="block-head">
        <text class="block-title">基金限额一览</text>
        <view class="block-filters">
          <picker mode="selector" range="{{fundScopeOptions}}" value="{{fundScopeIndex}}" bindchange="onScopeChange">
            <view class="filter-chip">{{fundScopeOptions[fundScopeIndex]}}</view>
          </picker>
          <picker mode="selector" range="{{sortOptions}}" value="{{sortIndex}}" bindchange="onSortChange">
            <view class="filter-chip">{{sortOptions[sortIndex]}}</view>
          </picker>
        </view>
      </view>

      <view class="fund-panel">
        <view class="fund-thead">
          <text class="th th-name">基金名称</text>
          <text class="th th-limit">当前限额</text>
          <text class="th th-status">状态</text>
          <text class="th th-time">更新时间</text>
        </view>

        <block wx:for="{{funds}}" wx:key="id">
          <view class="fund-row" data-id="{{item.id}}" bindtap="onFundTap">
            <view class="td td-name">
              <view class="logo" style="background: {{item.logoBg}}">{{item.abbr}}</view>
              <view class="name-wrap">
                <text class="fund-name">{{item.name}}</text>
                <text class="fund-code">{{item.code}}</text>
              </view>
            </view>
            <text class="td td-limit {{item.status === 'unavailable' ? 'td-limit--muted' : ''}}">{{item.limitText}}</text>
            <view class="td td-status">
              <text wx:if="{{item.status === 'available'}}" class="status-tag status-ok">可买</text>
              <text wx:elif="{{item.status === 'limited'}}" class="status-tag status-warn">限购</text>
              <text wx:else class="status-tag status-off">不可买</text>
            </view>
            <view class="td td-time">
              <text class="time-str">{{item.updatedAt}}</text>
              <text class="cell-arrow">›</text>
            </view>
          </view>
        </block>
      </view>

      <view class="quick-row">
        <view class="quick-card" data-key="fav" bindtap="onFeatureTap">
          <view class="quick-icon quick-icon--blue">
            <text class="quick-star">★</text>
          </view>
          <text class="quick-title">我的收藏</text>
          <text class="quick-desc">查看收藏的基金</text>
        </view>
        <view class="quick-card" data-key="remind" bindtap="onFeatureTap">
          <view class="quick-icon quick-icon--purple">
            <view class="mini-bell"></view>
          </view>
          <text class="quick-title">额度提醒</text>
          <text class="quick-desc">恢复申购实时通知</text>
        </view>
        <view class="quick-card" data-key="changes" bindtap="onFeatureTap">
          <view class="quick-icon quick-icon--green">
            <view class="mini-trend"></view>
          </view>
          <text class="quick-title">今日变化</text>
          <text class="quick-desc">查看额度变化榜</text>
        </view>
      </view>

      <view class="scroll-bottom-space"></view>
    </view>
  </scroll-view>

  <view class="tabbar" style="padding-bottom: {{safeBottom || 8}}px;">
    <view class="tab {{activeTab === 'home' ? 'tab--on' : ''}}" data-tab="home" bindtap="onTabTap">
      <view class="tab-ico tab-home"></view>
      <text class="tab-name">首页</text>
    </view>
    <view class="tab {{activeTab === 'watchlist' ? 'tab--on' : ''}}" data-tab="watchlist" bindtap="onTabTap">
      <view class="tab-ico tab-star"></view>
      <text class="tab-name">自选</text>
    </view>
    <view class="tab {{activeTab === 'remind' ? 'tab--on' : ''}}" data-tab="remind" bindtap="onTabTap">
      <view class="tab-ico tab-bell"></view>
      <text class="tab-name">提醒</text>
    </view>
    <view class="tab {{activeTab === 'me' ? 'tab--on' : ''}}" data-tab="me" bindtap="onTabTap">
      <view class="tab-ico tab-me"></view>
      <text class="tab-name">我的</text>
    </view>
  </view>
</view>
